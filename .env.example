# ============================================================
# 商标AI智能助手 - 环境配置
# 复制此文件为 .env 并填入真实值
# cp .env.example .env
# ============================================================

# -------- 阿里云 DashScope（大模型+文生图）--------
DASHSCOPE_API_KEY="sk-xxx"
DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# -------- 阿里云商标搜索API（国家商标网数据）--------
# 获取地址：https://market.aliyun.com/products/57002002/cmapi00046967.html
TRADEMARK_APPCODE="你的AppCode"

# -------- 邮件发送配置（到期提醒用）--------
# QQ邮箱SMTP为例，授权码获取：QQ邮箱 → 设置 → 账户 → POP3/SMTP服务
SMTP_HOST="smtp.qq.com"
SMTP_PORT=587
SMTP_USER="your_email@qq.com"
SMTP_PASSWORD="your_smtp_auth_code"
SMTP_FROM="your_email@qq.com"
